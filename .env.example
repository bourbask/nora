# Firefly III
# Generate APP_KEY: docker run --rm --env-file .env fireflyiii/core:latest php artisan key:generate
APP_KEY=

# Database (match docker-compose.yml)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=

APP_URL=http://localhost:8080
TRUSTED_PROXIES=**
ENABLE_EXTERNAL_IPS=1

# Firefly III Personal Access Token (UI: Options -> Profile -> OAuth -> Personal Access Tokens)
FIREFLY_III_ACCESS_TOKEN=

# Shared secret for the Data Importer /autoupload endpoint
AUTO_IMPORT_SECRET=

# Provider-specific secrets (scraper credentials, etc.) live in each provider's
# own local config under providers/<name>/, not here.
